<Window x:Class="TaskOverlay.App.WorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:webview="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="TaskOverlay Workspace"
        Icon="Assets/app.ico"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#FF0B0D0F"
        Loaded="WorkspaceWindow_OnLoaded"
        Closed="WorkspaceWindow_OnClosed">
    <Grid>
        <webview:WebView2 x:Name="WorkspaceWebView"
                          DefaultBackgroundColor="#0B0D0F" />
        <Border x:Name="ErrorPanel"
                Padding="28"
                Background="#FF101216"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="620">
                <TextBlock HorizontalAlignment="Center"
                           Foreground="#FFF2F2F3"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Text="Workspace could not be opened" />
                <TextBlock x:Name="ErrorMessageText"
                           Margin="0,12,0,0"
                           Foreground="#FFB3B8C2"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
