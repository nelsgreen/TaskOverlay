<UserControl x:Class="TaskOverlay.App.QuickAddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppWindowBrush}"
             FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18,12"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,1,0,1">
            <DockPanel>
                <Border DockPanel.Dock="Left"
                        Width="34"
                        Height="34"
                        Margin="0,0,11,0"
                        Background="#FF2B2E35"
                        BorderBrush="#FF494E58"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#FFE5C469"
                               FontSize="18"
                               Text="+" />
                </Border>
                <StackPanel>
                    <TextBlock Style="{StaticResource AppTitleStyle}"
                               Text="Quick Add task" />
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource AppSubtitleStyle}"
                               Text="Capture a task without breaking focus" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18,14,18,16">
                <Grid>
                    <TextBox x:Name="TitleTextBox"
                             Height="44"
                             Style="{StaticResource AppTextBoxStyle}"
                             FontSize="15"
                             FontWeight="SemiBold"
                             MaxLength="500"
                             TextChanged="InputTextBox_OnTextChanged"
                             GotKeyboardFocus="InputTextBox_OnKeyboardFocusChanged"
                             LostKeyboardFocus="InputTextBox_OnKeyboardFocusChanged" />
                    <TextBlock x:Name="TitlePlaceholder"
                               Margin="12,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Foreground="#FF747B87"
                               FontSize="14"
                               Text="What needs to be done?" />
                </Grid>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="PROJECT" />
                        <ListBox x:Name="ProjectListBox"
                                 Margin="0,9,0,4"
                                 Style="{StaticResource AppChipListStyle}"
                                 ItemContainerStyle="{StaticResource AppChipItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7"
                                                 Height="7"
                                                 Margin="0,0,7,0"
                                                 Fill="{Binding ColorHex}" />
                                        <TextBlock FontSize="11" Text="{Binding Name}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="STATUS" />
                        <ListBox x:Name="StatusListBox"
                                 Margin="0,9,0,0"
                                 Style="{StaticResource AppChipListStyle}"
                                 ItemContainerStyle="{StaticResource AppChipItemStyle}"
                                 SelectionChanged="StatusListBox_OnSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="{Binding Label}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="REMINDER" />
                        <ListBox x:Name="ReminderListBox"
                                 Margin="0,9,0,0"
                                 Style="{StaticResource AppChipListStyle}"
                                 ItemContainerStyle="{StaticResource AppChipItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="11" Text="{Binding Label}" />
                            </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border x:Name="WaitingCard"
                        Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="WAITING FOR" />
                        <TextBox x:Name="WaitingForTextBox"
                                 Margin="0,9,0,0"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 MaxLength="300" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="DESCRIPTION" />
                        <Grid Margin="0,9,0,0">
                            <TextBox x:Name="DescriptionTextBox"
                                     Height="76"
                                     Style="{StaticResource AppTextBoxStyle}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="InputTextBox_OnTextChanged"
                                     GotKeyboardFocus="InputTextBox_OnKeyboardFocusChanged"
                                     LostKeyboardFocus="InputTextBox_OnKeyboardFocusChanged" />
                            <TextBlock x:Name="DescriptionPlaceholder"
                                       Margin="12,9"
                                       VerticalAlignment="Top"
                                       IsHitTestVisible="False"
                                       Foreground="#FF747B87"
                                       FontSize="12"
                                       Text="Optional details..." />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="18,11"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="ValidationText"
                           Foreground="#FFF87171"
                           FontSize="11" />
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#FF7F8793"
                               FontSize="10"
                               Text="Enter to add &#183; Esc to cancel" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button MinWidth="82"
                                Margin="0,0,9,0"
                                Style="{StaticResource AppButtonStyle}"
                                Content="Cancel"
                                IsCancel="True"
                                Click="CancelButton_OnClick" />
                        <Button MinWidth="102"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Content="+  Add task"
                                IsDefault="True"
                                Click="AddButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
