<Window x:Class="TaskOverlay.App.DueAttentionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reminders"
        Width="340"
        MaxHeight="420"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False">
    <Border Margin="8"
            Padding="12"
            Background="#F2181B22"
            BorderBrush="#FFEF4444"
            BorderThickness="1"
            CornerRadius="8">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="0,0,0,8"
                       Foreground="#FFFCA5A5"
                       FontSize="11"
                       FontWeight="Bold"
                       Text="REMIND" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="DueItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    Background="#FF242832"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Foreground="#FFFFFFFF"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Margin="0,0,6,0"
                                                Padding="7,3"
                                                Focusable="False"
                                                Tag="{Binding TaskId}"
                                                Click="Focus_OnClick"
                                                Content="Focus" />
                                        <Button Margin="0,0,6,0"
                                                Padding="7,3"
                                                Focusable="False"
                                                Tag="{Binding TaskId}"
                                                Click="Snooze30_OnClick"
                                                Content="Snooze 30m" />
                                        <Button Margin="0,0,6,0"
                                                Padding="7,3"
                                                Focusable="False"
                                                Tag="{Binding TaskId}"
                                                Click="Snooze60_OnClick"
                                                Content="Snooze 60m" />
                                        <Button Margin="0,0,6,0"
                                                Padding="7,3"
                                                Focusable="False"
                                                Tag="{Binding TaskId}"
                                                Click="Done_OnClick"
                                                Content="Done" />
                                        <Button Padding="7,3"
                                                Focusable="False"
                                                Tag="{Binding TaskId}"
                                                Click="Clear_OnClick"
                                                Content="Remove reminder" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
