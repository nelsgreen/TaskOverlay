<Window x:Class="TaskOverlay.App.TreeManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tree Manager"
        Width="900"
        Height="720"
        MinWidth="680"
        MinHeight="480"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FF181B22">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Foreground="#FFF4F4F5"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Text="Task Tree" />
                    <TextBlock Margin="0,7,0,0"
                               Foreground="#FFA1A1AA"
                               FontSize="13"
                               Text="Projects, branches, tasks, and subtasks" />
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        MinWidth="84"
                        Padding="12,7"
                        Content="Refresh"
                        Click="RefreshButton_OnClick" />
            </DockPanel>

            <Border Grid.Row="1"
                    Margin="0,20,0,14"
                    Height="1"
                    Background="#FF3F3F46" />

            <Border Grid.Row="2"
                    Margin="0,0,0,18"
                    Padding="12"
                    Background="#FF20242D"
                    BorderBrush="#FF3F4654"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <WrapPanel>
                        <Button x:Name="NewProjectButton"
                                MinWidth="94"
                                Margin="0,0,8,8"
                                Padding="10,6"
                                Content="New project"
                                Click="NewProjectButton_OnClick" />
                        <Button x:Name="NewGroupButton"
                                MinWidth="94"
                                Margin="0,0,8,8"
                                Padding="10,6"
                                Content="New group"
                                Click="NewGroupButton_OnClick" />
                        <Button x:Name="NewTaskButton"
                                MinWidth="86"
                                Margin="0,0,8,8"
                                Padding="10,6"
                                Content="New task"
                                Click="NewTaskButton_OnClick" />
                        <Button x:Name="NewSubtaskButton"
                                MinWidth="94"
                                Margin="0,0,8,8"
                                Padding="10,6"
                                Content="New subtask"
                                Click="NewSubtaskButton_OnClick" />
                        <Button x:Name="RenameButton"
                                MinWidth="76"
                                Margin="0,0,8,8"
                                Padding="10,6"
                                Content="Rename"
                                Click="RenameButton_OnClick" />
                        <Button x:Name="DeleteButton"
                                MinWidth="70"
                                Margin="0,0,8,8"
                                Padding="10,6"
                                Content="Delete"
                                Click="DeleteButton_OnClick" />
                        <Button x:Name="MoveButton"
                                MinWidth="82"
                                Margin="0,0,0,8"
                                Padding="10,6"
                                Content="Move to..."
                                Click="MoveButton_OnClick" />
                    </WrapPanel>
                    <WrapPanel>
                        <Button x:Name="ActiveButton"
                                MinWidth="94"
                                Margin="0,0,8,0"
                                Padding="10,6"
                                Content="Set active"
                                Click="ActiveButton_OnClick" />
                        <Button x:Name="CompletionButton"
                                MinWidth="94"
                                Margin="0,0,8,0"
                                Padding="10,6"
                                Content="Complete"
                                Click="CompletionButton_OnClick" />
                        <TextBlock x:Name="SelectionStatus"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#FFA1A1AA"
                                   FontSize="12"
                                   Text="No selection" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <ListBox x:Name="TreeCards"
                     Grid.Row="3"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionChanged="TreeCards_OnSelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="{Binding IndentWidth}" />
                            <Border Grid.Column="1"
                                    Padding="14,11"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FF232731" />
                                        <Setter Property="BorderBrush" Value="#FF3F4654" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsProject}" Value="True">
                                                <Setter Property="Background" Value="#FF253047" />
                                                <Setter Property="BorderBrush" Value="#FF475E86" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                <Setter Property="Background" Value="#FF202B32" />
                                                <Setter Property="BorderBrush" Value="#FF3E5963" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="#FF34D399" />
                                                <Setter Property="Background" Value="#FF18352F" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                <Setter Property="Opacity" Value="0.68" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                         Value="True">
                                                <Setter Property="BorderBrush" Value="#FFFFE878" />
                                                <Setter Property="BorderThickness" Value="2" />
                                                <Setter Property="Background" Value="#FF34313A" />
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Foreground="#FF94A3B8"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding KindLabel}" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Margin="12,0,0,0"
                                                   Foreground="#FF6EE7B7"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding StatusLabel}" />
                                    </DockPanel>
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFF4F4F5" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                        <Setter Property="Foreground" Value="#FFA1A1AA" />
                                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
