<Window x:Class="TaskOverlay.App.TreeManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tree Manager"
        Icon="Assets/app.ico"
        Width="1220"
        Height="760"
        MinWidth="920"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#FF0B0D0F">
    <Window.Resources>
        <SolidColorBrush x:Key="TreeBackground" Color="#FF0B0D0F" />
        <SolidColorBrush x:Key="TreeSurface" Color="#FF151719" />
        <SolidColorBrush x:Key="TreeElevated" Color="#FF1C1F22" />
        <SolidColorBrush x:Key="TreeSelected" Color="#FF2A2E33" />
        <SolidColorBrush x:Key="TreeBorder" Color="#FF303438" />
        <SolidColorBrush x:Key="TreeText" Color="#FFF2F4F5" />
        <SolidColorBrush x:Key="TreeMuted" Color="#FF9AA5B1" />
        <SolidColorBrush x:Key="TreeGuide" Color="#FF4A5159" />
        <SolidColorBrush x:Key="TreeFocus" Color="#FF45D58A" />
        <SolidColorBrush x:Key="TreeDanger" Color="#FFDB646A" />

        <Style x:Key="TreeButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="{StaticResource TreeElevated}" />
            <Setter Property="Foreground" Value="{StaticResource TreeText}" />
            <Setter Property="BorderBrush" Value="{StaticResource TreeBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF292D31" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryTreeButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TreeButtonStyle}">
            <Setter Property="Background" Value="#FFE8ECEF" />
            <Setter Property="Foreground" Value="#FF111315" />
            <Setter Property="BorderBrush" Value="#FFE8ECEF" />
        </Style>

        <Style x:Key="DangerTreeButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TreeButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TreeDanger}" />
            <Setter Property="BorderBrush" Value="#FF633438" />
            <Setter Property="Background" Value="#FF211719" />
        </Style>

        <Style x:Key="FilterButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TreeButtonStyle}">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TreeMuted}" />
        </Style>

        <Style x:Key="TreeTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="#FF090A0B" />
            <Setter Property="Foreground" Value="{StaticResource TreeText}" />
            <Setter Property="CaretBrush" Value="{StaticResource TreeText}" />
            <Setter Property="BorderBrush" Value="{StaticResource TreeBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="TreeListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource TreeSelected}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF202327" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource TreeBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="96" />
            <RowDefinition Height="*" />
            <RowDefinition Height="84" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16,12"
                Background="#FF0E1012"
                BorderBrush="{StaticResource TreeBorder}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource TreeText}"
                               FontSize="19"
                               FontWeight="SemiBold"
                               Text="Task Tree" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="{StaticResource TreeMuted}"
                               FontSize="11"
                               Text="Organize projects, sections, tasks, and active overlay items" />
                </StackPanel>
                <Border Grid.Column="1"
                        Margin="8,10"
                        Padding="10,7"
                        Background="{StaticResource TreeElevated}"
                        BorderBrush="{StaticResource TreeBorder}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock x:Name="SelectedProjectLabel"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TreeText}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                </Border>
                <Grid Grid.Column="2"
                      Height="36"
                      Margin="8,10">
                    <TextBox x:Name="SearchBox"
                             VerticalContentAlignment="Center"
                             Style="{StaticResource TreeTextBoxStyle}"
                             ToolTip="Search or jump to a node"
                             TextChanged="SearchBox_OnTextChanged" />
                    <TextBlock Margin="11,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Foreground="#FF6F7882"
                               FontSize="12"
                               Text="Search or jump to...">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                                                 Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <StackPanel Grid.Column="3"
                            Margin="8,10,0,10"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button x:Name="NewProjectButton"
                            Style="{StaticResource TreeButtonStyle}"
                            Content="New project"
                            Click="NewProjectButton_OnClick" />
                    <Button x:Name="NewSectionButton"
                            Margin="8,0,0,0"
                            Style="{StaticResource TreeButtonStyle}"
                            Content="New section"
                            Click="NewSectionButton_OnClick" />
                    <Button x:Name="NewTaskButton"
                            Margin="8,0,0,0"
                            Style="{StaticResource PrimaryTreeButtonStyle}"
                            Content="New task"
                            Click="NewTaskButton_OnClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10,12"
                    Background="{StaticResource TreeSurface}"
                    BorderBrush="{StaticResource TreeBorder}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="2,0,2,8">
                        <TextBlock Foreground="{StaticResource TreeMuted}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Text="PROJECTS" />
                        <Button DockPanel.Dock="Right"
                                Width="24"
                                Height="22"
                                Padding="0"
                                Style="{StaticResource FilterButtonStyle}"
                                Content="+"
                                ToolTip="Create project"
                                Click="NewProjectButton_OnClick" />
                    </DockPanel>
                    <ListBox x:Name="ProjectList"
                             Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource TreeListBoxItemStyle}"
                             SelectionChanged="ProjectList_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="7,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{StaticResource TreeMuted}"
                                               FontSize="8"
                                               Text="&#x25C6;" />
                                    <TextBlock Grid.Column="1"
                                               Margin="7,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TreeText}"
                                               FontSize="13"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="2"
                                            MinWidth="20"
                                            Padding="5,2"
                                            Background="#FF34383D"
                                            CornerRadius="4"
                                            Visibility="{Binding ActiveCountVisibility}">
                                        <TextBlock HorizontalAlignment="Center"
                                                   Foreground="#FFD9DEE3"
                                                   FontSize="10"
                                                   Text="{Binding ActiveCount}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="ProjectSummary"
                               Grid.Row="2"
                               Margin="2,8,2,0"
                               Foreground="{StaticResource TreeMuted}"
                               FontSize="10" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="38" />
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Padding="12,0"
                        Background="#FF0D0F11"
                        BorderBrush="{StaticResource TreeBorder}"
                        BorderThickness="0,0,0,1">
                    <StackPanel VerticalAlignment="Bottom"
                                Orientation="Horizontal">
                        <Border Padding="12,7,12,8"
                                BorderBrush="{StaticResource TreeFocus}"
                                BorderThickness="0,0,0,2">
                            <TextBlock Foreground="{StaticResource TreeText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="Tree" />
                        </Border>
                        <Button Margin="4,0,0,1"
                                Padding="12,7"
                                Style="{StaticResource FilterButtonStyle}"
                                IsEnabled="False"
                                Content="Workstreams (later)"
                                ToolTip="Future alternate project view" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="1"
                        Padding="14,9"
                        Background="#FF0D0F11"
                        BorderBrush="{StaticResource TreeBorder}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock x:Name="TreePathLabel"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TreeText}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <Border HorizontalAlignment="Right"
                                Padding="3"
                                Background="{StaticResource TreeSurface}"
                                BorderBrush="{StaticResource TreeBorder}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="AllFilterButton"
                                        Style="{StaticResource FilterButtonStyle}"
                                        Content="All"
                                        Tag="All"
                                        Click="FilterButton_OnClick" />
                                <Button x:Name="ActiveOnlyFilterButton"
                                        Style="{StaticResource FilterButtonStyle}"
                                        Content="Active only"
                                        Tag="ActiveOnly"
                                        Click="FilterButton_OnClick" />
                                <Button x:Name="ActiveAncestorsFilterButton"
                                        Style="{StaticResource FilterButtonStyle}"
                                        Content="Active + ancestors"
                                        Tag="ActivePlusAncestors"
                                        Click="FilterButton_OnClick" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                <Grid Grid.Row="2">
                    <ListBox x:Name="TreeRows"
                             Margin="8"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ItemContainerStyle="{StaticResource TreeListBoxItemStyle}"
                             SelectionChanged="TreeRows_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1"
                                        CornerRadius="5">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Margin" Value="0,1" />
                                            <Setter Property="Padding" Value="6,4" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSection}" Value="True">
                                                    <Setter Property="Margin" Value="0,7,0,3" />
                                                    <Setter Property="Padding" Value="8,7" />
                                                    <Setter Property="Background" Value="#FF171B1F" />
                                                    <Setter Property="BorderBrush" Value="#FF394149" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                             Value="True">
                                                    <Setter Property="Background" Value="{StaticResource TreeSelected}" />
                                                    <Setter Property="BorderBrush" Value="#FF5A6570" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="{Binding IndentWidth}"
                                              Margin="0,-5,0,-5"
                                              Visibility="{Binding GuideVisibility}">
                                            <Border Width="1"
                                                    HorizontalAlignment="Right"
                                                    Background="{StaticResource TreeGuide}" />
                                            <Border Width="11"
                                                    Height="1"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Background="{StaticResource TreeGuide}" />
                                        </Grid>
                                        <Button Grid.Column="1"
                                                Width="22"
                                                Height="22"
                                                Padding="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource FilterButtonStyle}"
                                                Content="{Binding ExpandGlyph}"
                                                Visibility="{Binding ExpandVisibility}"
                                                ToolTip="Expand or collapse children"
                                                Click="ExpandButton_OnClick" />
                                        <Border Grid.Column="2"
                                                Margin="4,4,9,4"
                                                Padding="6,2"
                                                VerticalAlignment="Center"
                                                Background="#FF202428"
                                                BorderBrush="{Binding StatusBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Visibility="{Binding TaskVisibility}">
                                            <TextBlock Foreground="{Binding StatusBrush}"
                                                       FontSize="8"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding StatusLabel}" />
                                        </Border>
                                        <StackPanel Grid.Column="3"
                                                    Margin="0,4"
                                                    VerticalAlignment="Center">
                                            <TextBlock MaxHeight="44"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TreeText}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSection}" Value="True">
                                                                <Setter Property="FontSize" Value="14" />
                                                                <Setter Property="FontWeight" Value="Bold" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                <Setter Property="Foreground" Value="#FF747C85" />
                                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Margin="0,3,0,0"
                                                        Orientation="Horizontal"
                                                        Visibility="{Binding SectionVisibility}">
                                                <TextBlock Foreground="#FF7F94A8"
                                                           FontSize="9"
                                                           FontWeight="SemiBold"
                                                           Text="SECTION" />
                                                <TextBlock Margin="7,0,0,0"
                                                           Foreground="{StaticResource TreeMuted}"
                                                           FontSize="9"
                                                           Text="{Binding SectionSummary}" />
                                            </StackPanel>
                                            <TextBlock Margin="0,2,0,0"
                                                       Foreground="{StaticResource TreeMuted}"
                                                       FontSize="10"
                                                       Text="{Binding WaitingForLabel}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding WaitingForVisibility}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Opacity="0.62"
                                                    Orientation="Horizontal">
                                            <Button Width="24"
                                                    Height="22"
                                                    Padding="0"
                                                    Style="{StaticResource TreeButtonStyle}"
                                                    Content="&#x2191;"
                                                    IsEnabled="{Binding CanMoveUp}"
                                                    ToolTip="Move up"
                                                    Click="MoveUpButton_OnClick" />
                                            <Button Width="24"
                                                    Height="22"
                                                    Margin="3,0,0,0"
                                                    Padding="0"
                                                    Style="{StaticResource TreeButtonStyle}"
                                                    Content="&#x2193;"
                                                    IsEnabled="{Binding CanMoveDown}"
                                                    ToolTip="Move down"
                                                    Click="MoveDownButton_OnClick" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="TreeEmptyState"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TreeMuted}"
                               FontSize="13"
                               Text="No nodes match this view"
                               Visibility="Collapsed" />
                </Grid>
            </Grid>

            <Border Grid.Column="2"
                    Background="{StaticResource TreeSurface}"
                    BorderBrush="{StaticResource TreeBorder}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="62" />
                    </Grid.RowDefinitions>
                    <Border Padding="14,0"
                            BorderBrush="{StaticResource TreeBorder}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock x:Name="DetailsHeading"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TreeText}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="Edit item" />
                            <Border DockPanel.Dock="Right"
                                    Margin="8,10,0,10"
                                    Padding="7,2"
                                    Background="#FF25292D"
                                    BorderBrush="{StaticResource TreeBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <TextBlock x:Name="DetailsKindLabel"
                                           Foreground="{StaticResource TreeMuted}"
                                           FontSize="9" />
                            </Border>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14,12">
                            <TextBlock Foreground="{StaticResource TreeMuted}"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Text="TITLE" />
                            <TextBox x:Name="DetailsTitleInput"
                                     Margin="0,6,0,16"
                                     Style="{StaticResource TreeTextBoxStyle}" />

                            <TextBlock Foreground="{StaticResource TreeMuted}"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Text="TYPE" />
                            <Border Margin="0,6,0,16"
                                    Padding="10,7"
                                    Background="#FF22262A"
                                    BorderBrush="{StaticResource TreeBorder}"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <TextBlock x:Name="DetailsTypeValue"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource TreeText}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>

                            <StackPanel x:Name="TaskStatusPanel">
                                <TextBlock Foreground="{StaticResource TreeMuted}"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Text="STATUS" />
                                <UniformGrid Margin="0,6,0,16"
                                             Columns="4">
                                    <Button x:Name="TodoStatusButton"
                                            Margin="0,0,4,0"
                                            Padding="4,6"
                                            Style="{StaticResource TreeButtonStyle}"
                                            Content="TODO"
                                            Tag="Todo"
                                            Click="StatusButton_OnClick" />
                                    <Button x:Name="FocusStatusButton"
                                            Margin="0,0,4,0"
                                            Padding="4,6"
                                            Style="{StaticResource TreeButtonStyle}"
                                            Content="FOCUS"
                                            Tag="Focus"
                                            Click="StatusButton_OnClick" />
                                    <Button x:Name="WaitStatusButton"
                                            Margin="0,0,4,0"
                                            Padding="4,6"
                                            Style="{StaticResource TreeButtonStyle}"
                                            Content="WAIT"
                                            Tag="Wait"
                                            Click="StatusButton_OnClick" />
                                    <Button x:Name="DoneStatusButton"
                                            Padding="4,6"
                                            Style="{StaticResource TreeButtonStyle}"
                                            Content="DONE"
                                            Tag="Done"
                                            Click="StatusButton_OnClick" />
                                </UniformGrid>
                            </StackPanel>

                            <StackPanel x:Name="WaitingForPanel"
                                        Margin="0,0,0,16"
                                        Visibility="Collapsed">
                                <TextBlock Foreground="#FF67BFE0"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Text="WAITING FOR" />
                                <TextBox x:Name="WaitingForInput"
                                         Margin="0,6,0,0"
                                         Style="{StaticResource TreeTextBoxStyle}" />
                            </StackPanel>

                            <TextBlock x:Name="DetailsNotesLabel"
                                       Foreground="{StaticResource TreeMuted}"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Text="NOTES / DESCRIPTION" />
                            <TextBox x:Name="DetailsNotesInput"
                                     Height="86"
                                     Margin="0,6,0,4"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource TreeTextBoxStyle}" />
                            <TextBlock x:Name="DetailsNotesHint"
                                       Margin="0,0,0,16"
                                       Foreground="#FF727C86"
                                       FontSize="9"
                                       TextWrapping="Wrap" />

                            <TextBlock Foreground="{StaticResource TreeMuted}"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Text="ACTIONS" />
                            <TextBlock x:Name="CreateTargetHint"
                                       Margin="0,5,0,8"
                                       Foreground="#FF7F94A8"
                                       FontSize="10"
                                       TextWrapping="Wrap" />
                            <WrapPanel Margin="0,6,0,0">
                                <Button x:Name="AddSectionButton"
                                        Margin="0,0,6,6"
                                        Style="{StaticResource TreeButtonStyle}"
                                        Content="Add section"
                                        Click="AddSectionButton_OnClick" />
                                <Button x:Name="AddTaskButton"
                                        Margin="0,0,6,6"
                                        Style="{StaticResource TreeButtonStyle}"
                                        Content="Add task"
                                        Click="AddTaskButton_OnClick" />
                                <Button x:Name="AddSubtaskButton"
                                        Margin="0,0,6,6"
                                        Style="{StaticResource TreeButtonStyle}"
                                        Content="Add subtask"
                                        Click="AddSubtaskButton_OnClick" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Padding="12"
                            BorderBrush="{StaticResource TreeBorder}"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <Button x:Name="DeleteButton"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource DangerTreeButtonStyle}"
                                    Content="Delete"
                                    Click="DeleteButton_OnClick" />
                            <StackPanel HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                <Button Style="{StaticResource TreeButtonStyle}"
                                        Content="Cancel"
                                        Click="CancelButton_OnClick" />
                                <Button Margin="8,0,0,0"
                                        MinWidth="88"
                                        Style="{StaticResource PrimaryTreeButtonStyle}"
                                        Content="Save"
                                        Click="SaveButton_OnClick" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="14,8"
                Background="#FF0E1012"
                BorderBrush="{StaticResource TreeBorder}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource TreeText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="Active now" />
                    <StackPanel Margin="0,5,0,0"
                                Orientation="Horizontal">
                        <TextBlock Foreground="{StaticResource TreeMuted}"
                                   FontSize="9"
                                   Text="Feeds Working" />
                        <TextBlock x:Name="ActiveNowCount"
                                   Margin="8,0,0,0"
                                   Foreground="#FF7F94A8"
                                   FontSize="9" />
                    </StackPanel>
                </StackPanel>
                <ScrollViewer Grid.Column="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ActiveNowItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="200"
                                        Height="62"
                                        Margin="0,0,7,0"
                                        Padding="10,7"
                                        Background="{StaticResource TreeSurface}"
                                        BorderBrush="{StaticResource TreeBorder}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TreeText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Margin="0,4,0,0"
                                                    Orientation="Horizontal">
                                            <Border Padding="5,1"
                                                    BorderBrush="{Binding StatusBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                <TextBlock Foreground="{Binding StatusBrush}"
                                                           FontSize="8"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding StatusLabel}" />
                                            </Border>
                                            <TextBlock Margin="7,1,0,0"
                                                       Foreground="{StaticResource TreeMuted}"
                                                       FontSize="8"
                                                       Text="{Binding ProjectName}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
