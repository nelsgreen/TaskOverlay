<Window x:Class="TaskOverlay.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskOverlay v2"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True">
    <Grid x:Name="HoverSurface"
          Background="Transparent"
          MouseEnter="HoverSurface_OnMouseEnter"
          MouseLeave="HoverSurface_OnMouseLeave"
          PreviewMouseLeftButtonDown="HoverSurface_OnPreviewMouseLeftButtonDown"
          PreviewMouseMove="HoverSurface_OnPreviewMouseMove"
          PreviewMouseLeftButtonUp="HoverSurface_OnPreviewMouseLeftButtonUp"
          LostMouseCapture="HoverSurface_OnLostMouseCapture">
        <Border x:Name="CollapsedActivation"
                Width="42"
                Height="14"
                Margin="2"
                Background="#CC272A32"
                BorderBrush="#99FFE878"
                BorderThickness="1"
                CornerRadius="7"
                Visibility="Collapsed">
            <Rectangle Width="18"
                       Height="2"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Fill="#FFFFE878"
                       RadiusX="1"
                       RadiusY="1" />
        </Border>

        <Border x:Name="OverlayPanel"
                Padding="14"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel x:Name="ContentStack"
                        Width="420">
                <DockPanel x:Name="ActiveChrome"
                           LastChildFill="False"
                           Margin="2,0,2,10"
                           Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Left"
                               Foreground="#FFF4F4F5"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="TASKOVERLAY V2 PROTOTYPE" />
                    <TextBlock DockPanel.Dock="Right"
                               Foreground="#FFA1A1AA"
                               FontSize="11"
                               Text="ACTIVE" />
                </DockPanel>

                <ScrollViewer x:Name="TasksScroller"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ActiveTasks">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,1"
                                        Padding="0,3"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FocusVisualStyle="{x:Null}"
                                        Click="TaskRow_OnClick">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Stretch" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Margin="0,0,9,0"
                                                   VerticalAlignment="Top"
                                                   Foreground="#FFFFE878"
                                                   FontSize="16"
                                                   Text="&#x25CF;" />
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Foreground="#FFFFE878"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
