<Window x:Class="TaskOverlay.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TaskOverlay.App"
        Title="TaskOverlay v2"
        Icon="Assets/taskoverlay.ico"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True">
    <Window.Resources>
        <Style x:Key="TaskRowBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#80111418" />
            <Setter Property="BorderBrush" Value="#332F343D" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding InWork}" Value="True">
                    <Setter Property="Background" Value="#3310643B" />
                    <Setter Property="BorderBrush" Value="#6652D69A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                    <Setter Property="Background" Value="#261D4A5A" />
                    <Setter Property="BorderBrush" Value="#6657B7E8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsReminderDue}" Value="True">
                    <Setter Property="Background" Value="#332A1D09" />
                    <Setter Property="BorderBrush" Value="#99D89B32" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ProjectBadgeTemplate">
            <Button Margin="0,0,5,0"
                    Padding="0"
                    Background="{Binding ProjectColorHex}"
                    BorderThickness="0"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"
                    ToolTip="Click to change project"
                    Click="ProjectBadge_OnClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="5,1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock Foreground="#FFFFFFFF"
                           FontSize="9"
                           FontWeight="SemiBold"
                           MaxWidth="110"
                           Text="{Binding ProjectName}"
                           TextTrimming="CharacterEllipsis" />
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="FocusBadgeTemplate">
            <Border Margin="0,0,5,0"
                    Padding="5,1"
                    Background="#FF2563EB"
                    CornerRadius="3">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowFocusBadge}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Foreground="#FFFFFFFF"
                           FontSize="9"
                           FontWeight="Bold"
                           Text="FOCUS" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="WaitingBadgeTemplate">
            <Border Margin="0,0,5,0"
                    Padding="5,1"
                    Background="#FFB45309"
                    CornerRadius="3">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Foreground="#FFFFFFFF"
                           FontSize="9"
                           FontWeight="Bold"
                           Text="WAIT" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StatusBadgeTemplate">
            <Border Margin="0,0,5,0"
                    Padding="5,1"
                    Background="{Binding StatusBackgroundHex}"
                    CornerRadius="3">
                <TextBlock Foreground="{Binding StatusForegroundHex}"
                           FontSize="9"
                           FontWeight="Bold"
                           Text="{Binding StatusLabel}" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ReminderBadgeTemplate">
            <Button Padding="0"
                    Background="#FF8A5A00"
                    BorderThickness="0"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"
                    ToolTip="Click to snooze, complete, or clear"
                    Click="DueBadge_OnClick">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsReminderDue}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="6,1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.ContextMenu>
                    <ContextMenu Opened="TaskContextMenu_OnOpened"
                                 Closed="TaskContextMenu_OnClosed"
                                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Focus" Click="FocusReminderMenuItem_OnClick" />
                        <MenuItem Header="Snooze 30m" Click="Snooze30MenuItem_OnClick" />
                        <MenuItem Header="Snooze 1h" Click="Snooze1HourMenuItem_OnClick" />
                        <MenuItem Header="Still waiting" Click="StillWaitingMenuItem_OnClick" />
                        <Separator />
                        <MenuItem Header="Mark done" Click="CompleteTaskMenuItem_OnClick" />
                        <MenuItem Header="Open details" Click="EditTaskMenuItem_OnClick" />
                        <MenuItem Header="Clear reminder" Click="ClearReminderMenuItem_OnClick" />
                    </ContextMenu>
                </Button.ContextMenu>
                <TextBlock Foreground="#FFFFFFFF"
                           FontSize="9"
                           FontWeight="Bold"
                           Text="REMIND" />
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="TaskBodyTemplate">
            <Button Padding="0,2"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"
                    Click="TaskBody_OnClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Stretch" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{Binding TitleColorHex}"
                               FontSize="{Binding TitleFontSize}"
                               FontWeight="SemiBold"
                               Text="{Binding Title}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,5,0,2"
                               Foreground="#FFD4D4D8"
                               FontSize="{Binding DescriptionFontSize}"
                               LineHeight="{Binding DescriptionLineHeight}"
                               MaxHeight="{Binding DescriptionMaxHeight}"
                               Text="{Binding Description}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowDescription}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Margin="0,3,0,1"
                               Foreground="{Binding ReminderMetadataColorHex}"
                               FontSize="11"
                               Text="{Binding ReminderMetadataLabel}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowReminderMetadata}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Margin="0,3,0,1"
                               Foreground="#FF7DD3FC"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="{Binding WaitingForLabel}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowWaitingFor}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="ExpandedTaskRowTemplate">
            <Border Margin="{Binding RowMargin}"
                    Padding="{Binding RowPadding}"
                    Opacity="{Binding RowOpacity}"
                    CornerRadius="6"
                    Style="{StaticResource TaskRowBorderStyle}"
                    MouseLeftButtonUp="TaskRow_OnMouseLeftButtonUp"
                    ContextMenuOpening="TaskRow_OnContextMenuOpening">
                <Border.ContextMenu>
                    <ContextMenu Opened="TaskContextMenu_OnOpened"
                                 Closed="TaskContextMenu_OnClosed"
                                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" />
                </Border.ContextMenu>
                <StackPanel>
                    <WrapPanel Margin="0,0,0,3">
                        <ContentControl Content="{Binding}"
                                        ContentTemplate="{StaticResource StatusBadgeTemplate}" />
                        <ContentControl Content="{Binding}"
                                        ContentTemplate="{StaticResource ReminderBadgeTemplate}" />
                    </WrapPanel>
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource TaskBodyTemplate}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="WorkingTaskRowTemplate">
            <Border Margin="{Binding RowMargin}"
                    Padding="{Binding RowPadding}"
                    Opacity="{Binding RowOpacity}"
                    CornerRadius="6"
                    Style="{StaticResource TaskRowBorderStyle}"
                    MouseLeftButtonUp="TaskRow_OnMouseLeftButtonUp"
                    ContextMenuOpening="TaskRow_OnContextMenuOpening">
                <Border.ContextMenu>
                    <ContextMenu Opened="TaskContextMenu_OnOpened"
                                 Closed="TaskContextMenu_OnClosed"
                                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" />
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0"
                             Width="8"
                             Height="8"
                             Margin="0,7,8,0"
                             VerticalAlignment="Top"
                             Fill="{Binding StatusDotColorHex}"
                             ToolTip="Status indicator" />
                    <StackPanel Grid.Column="1">
                        <WrapPanel Margin="0,0,0,3">
                            <ContentControl Content="{Binding}"
                                            ContentTemplate="{StaticResource ProjectBadgeTemplate}" />
                            <ContentControl Content="{Binding}"
                                            ContentTemplate="{StaticResource WaitingBadgeTemplate}" />
                            <ContentControl Content="{Binding}"
                                            ContentTemplate="{StaticResource ReminderBadgeTemplate}" />
                        </WrapPanel>
                        <ContentControl Content="{Binding}"
                                        ContentTemplate="{StaticResource TaskBodyTemplate}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="OverlayFilterChipTemplate">
            <Button Margin="0,0,5,5"
                    Padding="0"
                    BorderThickness="1"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"
                    Click="OverlayFilter_OnClick">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#B3111418" />
                        <Setter Property="BorderBrush" Value="#FF30343B" />
                        <Setter Property="Foreground" Value="#FFB8BCC6" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="#FF263440" />
                                <Setter Property="BorderBrush" Value="#FF6B8299" />
                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FF7C8795" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="7,3"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Text="{Binding Label}" />
                    <TextBlock Margin="4,0,0,0"
                               Foreground="#FF8F96A3"
                               FontSize="9"
                               Text="{Binding Count}" />
                </StackPanel>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="OverlayProjectGroupTemplate">
            <StackPanel Margin="0,0,0,7">
                <DockPanel Margin="3,0,3,4">
                    <Border DockPanel.Dock="Right"
                            MinWidth="20"
                            Padding="5,1"
                            Background="#FF272A30"
                            CornerRadius="7">
                        <TextBlock HorizontalAlignment="Center"
                                   Foreground="#FFA1A1AA"
                                   FontSize="9"
                                   Text="{Binding Count}" />
                    </Border>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="7"
                                Height="7"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Background="{Binding ProjectColorHex}"
                                CornerRadius="4" />
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#FFE4E4E7"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="{Binding ProjectName}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DockPanel>
                <ItemsControl ItemsSource="{Binding Tasks}"
                              ItemTemplate="{StaticResource ExpandedTaskRowTemplate}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:WorkingOverlayViewState}">
            <StackPanel Width="{Binding ContentWidth}">
                <ScrollViewer MaxHeight="{Binding TasksMaxHeight}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Margin="8,6"
                                   Foreground="#FFA1A1AA"
                                   FontSize="{Binding EmptyFontSize}"
                                   FontWeight="SemiBold"
                                   Opacity="{Binding EmptyOpacity}"
                                   Text="{Binding EmptyText}"
                                   Visibility="{Binding EmptyVisibility}" />
                        <ItemsControl ItemsSource="{Binding Tasks}"
                                      ItemTemplate="{StaticResource WorkingTaskRowTemplate}" />
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:CollapsedOverlayViewState}">
            <Grid Width="0" Height="0" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:ExpandedOverlayViewState}">
            <StackPanel Width="{Binding ContentWidth}">
                <StackPanel Visibility="{Binding ActiveHeaderVisibility}">
                    <DockPanel LastChildFill="False"
                               Margin="2,0,2,7">
                        <TextBlock DockPanel.Dock="Left"
                                   Foreground="#FFF4F4F5"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="TaskOverlay" />
                        <TextBlock DockPanel.Dock="Right"
                                   Foreground="#FFA1A1AA"
                                   FontSize="10"
                                   Text="{Binding ModeStatus}" />
                    </DockPanel>
                    <ItemsControl Margin="0,0,0,5"
                                  ItemsSource="{Binding FilterOptions}"
                                  ItemTemplate="{StaticResource OverlayFilterChipTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
                <ScrollViewer MaxHeight="{Binding TasksMaxHeight}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Margin="8,6"
                                   Foreground="#FFA1A1AA"
                                   FontSize="{Binding EmptyFontSize}"
                                   FontWeight="SemiBold"
                                   Opacity="{Binding EmptyOpacity}"
                                   Text="{Binding EmptyText}"
                                   Visibility="{Binding EmptyVisibility}" />
                        <ItemsControl ItemsSource="{Binding ProjectGroups}"
                                      ItemTemplate="{StaticResource OverlayProjectGroupTemplate}" />
                        <StackPanel Visibility="{Binding WaitGroupVisibility}">
                            <Button Margin="0,1,0,5"
                                    Padding="0"
                                    HorizontalContentAlignment="Stretch"
                                    Background="#B3151A20"
                                    BorderBrush="#FF304A59"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"
                                    Click="WaitGroupHeader_OnClick">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="8,5"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <DockPanel>
                                                <Border DockPanel.Dock="Right"
                                                        MinWidth="20"
                                                        Padding="5,1"
                                                        Background="#FF0C4A6E"
                                                        CornerRadius="7">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               Foreground="#FFBAE6FD"
                                                               FontSize="9"
                                                               Text="{Binding WaitCount}" />
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Margin="0,0,6,0"
                                                               Foreground="#FF7DD3FC"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="10"
                                                               Text="{Binding WaitToggleGlyph}" />
                                                    <TextBlock Foreground="#FF7DD3FC"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               Text="WAIT" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <ItemsControl ItemsSource="{Binding WaitProjectGroups}"
                                          ItemTemplate="{StaticResource OverlayProjectGroupTemplate}"
                                          Visibility="{Binding WaitTasksVisibility}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="HoverSurface"
          Background="Transparent"
          IsHitTestVisible="{Binding Content.IsHostHitTestVisible, ElementName=OverlayContent}"
          MouseEnter="HoverSurface_OnMouseEnter"
          MouseLeave="HoverSurface_OnMouseLeave"
          PreviewMouseLeftButtonDown="HoverSurface_OnPreviewMouseLeftButtonDown"
          PreviewMouseMove="HoverSurface_OnPreviewMouseMove"
          PreviewMouseLeftButtonUp="HoverSurface_OnPreviewMouseLeftButtonUp"
          LostMouseCapture="HoverSurface_OnLostMouseCapture">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="CollapsedActivation"
                Grid.Row="0"
                Width="44"
                Height="16"
                Margin="2"
                HorizontalAlignment="Left"
                Background="#CC272A32"
                BorderBrush="#99FFE878"
                BorderThickness="1"
                CornerRadius="8"
                Cursor="SizeAll"
                ToolTip="Overlay mode"
                PreviewMouseLeftButtonDown="ActivationHandle_OnPreviewMouseLeftButtonDown"
                PreviewMouseMove="ActivationHandle_OnPreviewMouseMove"
                PreviewMouseLeftButtonUp="ActivationHandle_OnPreviewMouseLeftButtonUp"
                LostMouseCapture="ActivationHandle_OnLostMouseCapture">
            <Border.ContextMenu>
                <ContextMenu Opened="HandleModeContextMenu_OnOpened"
                             Closed="HandleModeContextMenu_OnClosed">
                    <MenuItem Header="Working"
                              Tag="Working"
                              IsCheckable="True"
                              Click="HandleModeMenuItem_OnClick" />
                    <MenuItem Header="Pinned"
                              Tag="PinnedExpanded"
                              IsCheckable="True"
                              Click="HandleModeMenuItem_OnClick" />
                    <MenuItem Header="Collapsed handle"
                              Tag="CollapsedHandle"
                              IsCheckable="True"
                              Click="HandleModeMenuItem_OnClick" />
                </ContextMenu>
            </Border.ContextMenu>
            <Rectangle x:Name="HandleIndicator"
                       Width="18"
                       Height="2"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Fill="#FFFFE878"
                       RadiusX="1"
                       RadiusY="1" />
        </Border>

        <Border x:Name="OverlayPanel"
                Grid.Row="1"
                Padding="14"
                Background="{Binding Content.PanelBackground, ElementName=OverlayContent}"
                BorderBrush="{Binding Content.PanelBorder, ElementName=OverlayContent}"
                BorderThickness="1"
                CornerRadius="10"
                MaxWidth="{Binding Content.PanelMaxWidth, ElementName=OverlayContent}">
            <ContentControl x:Name="OverlayContent" />
        </Border>
    </Grid>
</Window>
