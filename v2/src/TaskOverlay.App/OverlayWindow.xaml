<Window x:Class="TaskOverlay.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskOverlay v2"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True">
    <Grid x:Name="HoverSurface"
          Background="Transparent"
          MouseEnter="HoverSurface_OnMouseEnter"
          MouseLeave="HoverSurface_OnMouseLeave">
        <Border x:Name="OverlayPanel"
                Padding="14"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel MinWidth="300">
                <DockPanel x:Name="ActiveChrome"
                           LastChildFill="False"
                           Margin="2,0,2,10"
                           Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Left"
                               Foreground="#FFF4F4F5"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="TASKOVERLAY V2 PROTOTYPE" />
                    <TextBlock DockPanel.Dock="Right"
                               Foreground="#FFA1A1AA"
                               FontSize="11"
                               Text="ACTIVE" />
                </DockPanel>

                <TextBlock Margin="0,4"
                           Foreground="#FFFFE878"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="•  Validate transparent overlay" />
                <TextBlock Margin="0,4"
                           Foreground="#FFFFE878"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="•  Test tray lifecycle" />
                <TextBlock Margin="0,4"
                           Foreground="#FFFFE878"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="•  Check DPI and hover behavior" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
