<Window x:Class="TaskOverlay.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskOverlay v2"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True">
    <Grid x:Name="HoverSurface"
          Background="Transparent"
          MouseEnter="HoverSurface_OnMouseEnter"
          MouseLeave="HoverSurface_OnMouseLeave">
        <Border x:Name="OverlayPanel"
                Padding="14"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel MinWidth="300">
                <DockPanel x:Name="ActiveChrome"
                           LastChildFill="False"
                           Margin="2,0,2,10"
                           Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Left"
                               Foreground="#FFF4F4F5"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="TASKOVERLAY V2 PROTOTYPE" />
                    <TextBlock DockPanel.Dock="Right"
                               Foreground="#FFA1A1AA"
                               FontSize="11"
                               Text="ACTIVE" />
                </DockPanel>

                <ItemsControl x:Name="ActiveTasks">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,1"
                                    Padding="0,3"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"
                                    Click="TaskRow_OnClick">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Margin="0,0,9,0"
                                               VerticalAlignment="Center"
                                               Foreground="#FFFFE878"
                                               FontSize="16"
                                               Text="&#x25CF;" />
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="#FFFFE878"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</Window>
