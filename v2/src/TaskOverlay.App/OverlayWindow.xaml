<Window x:Class="TaskOverlay.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskOverlay v2"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True">
    <Grid x:Name="HoverSurface"
          Background="Transparent"
          MouseEnter="HoverSurface_OnMouseEnter"
          MouseLeave="HoverSurface_OnMouseLeave"
          PreviewMouseLeftButtonDown="HoverSurface_OnPreviewMouseLeftButtonDown"
          PreviewMouseMove="HoverSurface_OnPreviewMouseMove"
          PreviewMouseLeftButtonUp="HoverSurface_OnPreviewMouseLeftButtonUp"
          LostMouseCapture="HoverSurface_OnLostMouseCapture">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="CollapsedActivation"
                Grid.Row="0"
                Width="44"
                Height="16"
                Margin="2"
                HorizontalAlignment="Left"
                Background="#CC272A32"
                BorderBrush="#99FFE878"
                BorderThickness="1"
                CornerRadius="8"
                Cursor="SizeAll"
                ToolTip="Overlay mode"
                PreviewMouseLeftButtonDown="ActivationHandle_OnPreviewMouseLeftButtonDown"
                PreviewMouseMove="ActivationHandle_OnPreviewMouseMove"
                PreviewMouseLeftButtonUp="ActivationHandle_OnPreviewMouseLeftButtonUp"
                LostMouseCapture="ActivationHandle_OnLostMouseCapture">
            <Border.ContextMenu>
                <ContextMenu Opened="HandleModeContextMenu_OnOpened"
                             Closed="HandleModeContextMenu_OnClosed">
                    <MenuItem Header="Auto quest tracker"
                              Tag="AutoQuestTracker"
                              IsCheckable="True"
                              Click="HandleModeMenuItem_OnClick" />
                    <MenuItem Header="Collapsed handle"
                              Tag="CollapsedHandle"
                              IsCheckable="True"
                              Click="HandleModeMenuItem_OnClick" />
                    <MenuItem Header="Pinned expanded"
                              Tag="PinnedExpanded"
                              IsCheckable="True"
                              Click="HandleModeMenuItem_OnClick" />
                </ContextMenu>
            </Border.ContextMenu>
            <Rectangle x:Name="HandleIndicator"
                       Width="18"
                       Height="2"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Fill="#FFFFE878"
                       RadiusX="1"
                       RadiusY="1" />
        </Border>

        <Border x:Name="OverlayPanel"
                Grid.Row="1"
                Padding="14"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel x:Name="ContentStack"
                        Width="420">
                <DockPanel x:Name="ActiveChrome"
                           LastChildFill="False"
                           Margin="2,0,2,10"
                           Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Left"
                               Foreground="#FFF4F4F5"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="TASKOVERLAY V2 PROTOTYPE" />
                    <TextBlock x:Name="ModeStatus"
                               DockPanel.Dock="Right"
                               Foreground="#FFA1A1AA"
                               FontSize="11"
                               Text="ACTIVE" />
                </DockPanel>

                <ScrollViewer x:Name="TasksScroller"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ActiveTasks">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,1"
                                        Padding="0,2"
                                        CornerRadius="5"
                                        ContextMenuOpening="TaskRow_OnContextMenuOpening">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding InWork}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="#3329B6F6" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.ContextMenu>
                                        <ContextMenu Opened="TaskContextMenu_OnOpened"
                                                     Closed="TaskContextMenu_OnClosed"
                                                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Edit"
                                                      Click="EditTaskMenuItem_OnClick" />
                                            <MenuItem Header="Show description"
                                                      Click="ToggleDescriptionMenuItem_OnClick" />
                                            <MenuItem Header="Mark as in work"
                                                      Click="ToggleInWorkMenuItem_OnClick" />
                                            <Separator />
                                            <MenuItem Header="Mark completed"
                                                      Click="CompleteTaskMenuItem_OnClick" />
                                            <MenuItem Header="Delete"
                                                      Click="DeleteTaskMenuItem_OnClick" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Width="28"
                                                MinHeight="30"
                                                Margin="0,0,4,0"
                                                VerticalAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FocusVisualStyle="{x:Null}"
                                                ToolTip="Mark completed"
                                                Click="TaskMarker_OnClick">
                                            <TextBlock VerticalAlignment="Top"
                                                       Foreground="#FFFFE878"
                                                       FontSize="16"
                                                       Text="&#x25CF;" />
                                        </Button>

                                        <Button Grid.Column="1"
                                                Padding="0,2"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FocusVisualStyle="{x:Null}"
                                                Click="TaskBody_OnClick">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Padding="{TemplateBinding Padding}"
                                                            Background="Transparent">
                                                        <ContentPresenter HorizontalAlignment="Stretch" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel>
                                                <TextBlock VerticalAlignment="Center"
                                                           Foreground="#FFFFE878"
                                                           FontSize="20"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Title}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,5,0,2"
                                                           Foreground="#FFD4D4D8"
                                                           FontSize="13"
                                                           Text="{Binding Description}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowDescription}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
