<Window x:Class="TaskOverlay.App.BackupRestorePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Newer backup found"
        Width="430"
        Height="270"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppWindowBrush}"
        Icon="Assets/app.ico"
        ShowInTaskbar="False"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Margin="20,18">
            <TextBlock x:Name="PromptTitleText"
                       Style="{StaticResource AppTitleStyle}"
                       Text="Newer backup found" />
            <TextBlock x:Name="PromptSubtitleText"
                       Margin="0,5,0,15"
                       Style="{StaticResource AppSubtitleStyle}"
                       Text="A newer Work backup is available in the shared backup folder." />
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="LocalStateText"
                               Foreground="{StaticResource AppTextBrush}"
                               FontSize="12" />
                    <TextBlock x:Name="CurrentMachineText"
                               Margin="0,4,0,0"
                               Style="{StaticResource AppSubtitleStyle}" />
                    <Separator Margin="0,10" Background="{StaticResource AppBorderBrush}" />
                    <TextBlock x:Name="BackupStateText"
                               Foreground="{StaticResource AppTextBrush}"
                               FontSize="12" />
                    <TextBlock x:Name="BackupSourceText"
                               Margin="0,4,0,0"
                               Style="{StaticResource AppSubtitleStyle}" />
                </StackPanel>
            </Border>
            <TextBlock x:Name="LocalNewerWarningText"
                       Margin="0,12,0,0"
                       Foreground="#FFDB646A"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Text="This backup is older than your local state. Restoring it will replace newer local data."
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />
            <TextBlock Margin="0,12,0,0"
                       Foreground="{StaticResource AppTextBrush}"
                       FontSize="12"
                       Text="Restore backup from shared folder?" />
        </StackPanel>
        <Border Grid.Row="1"
                Padding="16,11"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button MinWidth="82"
                        Margin="0,0,9,0"
                        Style="{StaticResource AppButtonStyle}"
                        Content="Skip"
                        IsCancel="True"
                        Click="SkipButton_OnClick" />
                <Button MinWidth="92"
                        Style="{StaticResource AppPrimaryButtonStyle}"
                        Content="Restore"
                        IsDefault="True"
                        Click="RestoreButton_OnClick" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
