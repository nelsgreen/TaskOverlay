<Window x:Class="TaskOverlay.App.TaskDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task details"
        Icon="Assets/app.ico"
        Width="620"
        Height="760"
        MinWidth="500"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Background="#FF181B22">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Foreground="#FFF4F4F5"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Text="Task details" />

            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                <TextBlock Foreground="#FFD4D4D8" Text="Title" />
                <TextBox x:Name="TitleTextBox"
                         Margin="0,7,0,0"
                         Padding="8"
                         FontSize="15"
                         MaxLength="500" />
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Foreground="#FFD4D4D8" Text="Project" />
                    <ComboBox x:Name="ProjectComboBox"
                              Margin="0,7,0,0"
                              Padding="7,5"
                              DisplayMemberPath="Name" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Foreground="#FFD4D4D8" Text="Status" />
                    <ComboBox x:Name="StatusComboBox"
                              Margin="0,7,0,0"
                              Padding="7,5"
                              DisplayMemberPath="Label"
                              SelectionChanged="StatusComboBox_OnSelectionChanged" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                <TextBlock Foreground="#FFD4D4D8" Text="Waiting for" />
                <TextBox x:Name="WaitingForTextBox"
                         Margin="0,7,0,0"
                         Padding="8"
                         MaxLength="300" />
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,16,0,0">
                <TextBlock Foreground="#FFD4D4D8" Text="Reminder preset" />
                <ComboBox x:Name="ReminderPresetComboBox"
                          Margin="0,7,0,0"
                          Padding="7,5"
                          DisplayMemberPath="Label" />
            </StackPanel>

            <Grid Grid.Row="5" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Foreground="#FFD4D4D8"
                               Text="Remind at (local yyyy-MM-dd HH:mm)" />
                    <TextBox x:Name="RemindAtTextBox"
                             Margin="0,7,0,0"
                             Padding="8" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Foreground="#FFD4D4D8" Text="Repeat" />
                    <ComboBox x:Name="RepeatComboBox"
                              Margin="0,7,0,0"
                              Padding="7,5"
                              DisplayMemberPath="Label" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="6" Margin="0,16,0,0">
                <TextBlock Foreground="#FFD4D4D8" Text="Description" />
                <TextBox x:Name="DescriptionTextBox"
                         Margin="0,7,0,0"
                         Padding="8"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <DockPanel Grid.Row="7" Margin="0,24,0,0">
                <Button DockPanel.Dock="Left"
                        MinWidth="88"
                        Padding="12,7"
                        Foreground="#FFF4F4F5"
                        Background="#FF7F1D1D"
                        BorderBrush="#FF991B1B"
                        Content="Delete"
                        Click="DeleteButton_OnClick" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button MinWidth="88"
                            Margin="0,0,10,0"
                            Padding="12,7"
                            Content="Cancel"
                            Click="CancelButton_OnClick" />
                    <Button MinWidth="88"
                            Padding="12,7"
                            Content="Save"
                            IsDefault="True"
                            Click="SaveButton_OnClick" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
