<Window x:Class="TaskOverlay.App.TaskDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task details"
        Width="560"
        Height="500"
        MinWidth="420"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Background="#FF181B22">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Foreground="#FFF4F4F5"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Text="Task details" />

            <StackPanel Grid.Row="1"
                        Margin="0,20,0,0">
                <TextBlock Foreground="#FFD4D4D8"
                           Text="Title" />
                <TextBox x:Name="TitleTextBox"
                         Margin="0,7,0,0"
                         Padding="8"
                         FontSize="15"
                         MaxLength="500" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Margin="0,18,0,0">
                <TextBlock Foreground="#FFD4D4D8"
                           Text="Description" />
                <TextBox x:Name="DescriptionTextBox"
                         Margin="0,7,0,0"
                         Padding="8"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Margin="0,18,0,0"
                        Orientation="Horizontal">
                <CheckBox x:Name="InWorkCheckBox"
                          Margin="0,0,24,0"
                          Foreground="#FFF4F4F5"
                          Content="In work" />
                <CheckBox x:Name="CompletedCheckBox"
                          Foreground="#FFF4F4F5"
                          Content="Completed" />
            </StackPanel>

            <DockPanel Grid.Row="4"
                       Margin="0,24,0,0">
                <Button DockPanel.Dock="Left"
                        MinWidth="88"
                        Padding="12,7"
                        Foreground="#FFF4F4F5"
                        Background="#FF7F1D1D"
                        BorderBrush="#FF991B1B"
                        Content="Delete"
                        Click="DeleteButton_OnClick" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button MinWidth="88"
                            Margin="0,0,10,0"
                            Padding="12,7"
                            Content="Cancel"
                            Click="CancelButton_OnClick" />
                    <Button MinWidth="88"
                            Padding="12,7"
                            Content="Save"
                            IsDefault="True"
                            Click="SaveButton_OnClick" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
