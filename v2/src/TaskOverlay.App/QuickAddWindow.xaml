<Window x:Class="TaskOverlay.App.QuickAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Add task"
        Icon="Assets/app.ico"
        Width="560"
        Height="650"
        MinWidth="460"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Grid Background="#FF181B22">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Foreground="#FFF4F4F5"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Text="Quick Add task" />

            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                <TextBlock Foreground="#FFD4D4D8" Text="Title" />
                <TextBox x:Name="TitleTextBox"
                         Margin="0,7,0,0"
                         Padding="8"
                         FontSize="15"
                         MaxLength="500" />
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Foreground="#FFD4D4D8" Text="Project" />
                    <ComboBox x:Name="ProjectComboBox"
                              Margin="0,7,0,0"
                              Padding="7,5"
                              DisplayMemberPath="Name" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Foreground="#FFD4D4D8" Text="Status" />
                    <ComboBox x:Name="StatusComboBox"
                              Margin="0,7,0,0"
                              Padding="7,5"
                              DisplayMemberPath="Label"
                              SelectionChanged="StatusComboBox_OnSelectionChanged" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                <TextBlock Foreground="#FFD4D4D8" Text="Reminder" />
                <ComboBox x:Name="ReminderComboBox"
                          Margin="0,7,0,0"
                          Padding="7,5"
                          DisplayMemberPath="Label" />
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,16,0,0">
                <TextBlock Foreground="#FFD4D4D8" Text="Waiting for" />
                <TextBox x:Name="WaitingForTextBox"
                         Margin="0,7,0,0"
                         Padding="8"
                         MaxLength="300" />
            </StackPanel>

            <TextBlock x:Name="ValidationText"
                       Grid.Row="5"
                       Margin="0,10,0,0"
                       Foreground="#FFF87171"
                       FontSize="12" />

            <StackPanel Grid.Row="6" Margin="0,16,0,0">
                <TextBlock Foreground="#FFD4D4D8" Text="Description" />
                <TextBox x:Name="DescriptionTextBox"
                         Margin="0,7,0,0"
                         Padding="8"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <StackPanel Grid.Row="7"
                        Margin="0,24,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button MinWidth="88"
                        Margin="0,0,10,0"
                        Padding="12,7"
                        Content="Cancel"
                        IsCancel="True"
                        Click="CancelButton_OnClick" />
                <Button MinWidth="88"
                        Padding="12,7"
                        Content="Add"
                        IsDefault="True"
                        Click="AddButton_OnClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
