<UserControl x:Class="TaskOverlay.App.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppWindowBrush}"
             FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18,12"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,1,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="34"
                        Height="34"
                        Margin="0,0,11,0"
                        Background="#FF2B2E35"
                        BorderBrush="#FF494E58"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#FFE5C469"
                               FontSize="16"
                               Text="*" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource AppTitleStyle}"
                               Text="Settings" />
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource AppSubtitleStyle}"
                               Text="Overlay behavior, Working appearance, hotkeys, and window sizing" />
                </StackPanel>
                <Border Grid.Column="2"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Background="#FF312A17"
                        BorderBrush="#FF66501D"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock Foreground="#FFE2BE5D"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Text="Auto-saved" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18,14,18,16">
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="CURRENT MODE" />
                        <ListBox x:Name="ModeListBox"
                                 Margin="0,10,0,2"
                                 Style="{StaticResource AppChipListStyle}"
                                 ItemContainerStyle="{StaticResource AppChipItemStyle}"
                                 SelectionChanged="ModeListBox_OnSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="11" Text="{Binding Label}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Style="{StaticResource AppSubtitleStyle}"
                                   Text="Cycle modes anytime with Ctrl Alt 1." />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="MEET RECORDING &amp; ASSISTANT" />
                        <CheckBox x:Name="AutomaticMeetingRecordingCheckBox"
                                  Margin="0,10,0,0"
                                  VerticalContentAlignment="Center"
                                  Foreground="{StaticResource AppTextBrush}"
                                  FontSize="11"
                                  Content="Enable automatic recording for eligible MEETs"
                                  Checked="MeetingAssistantSettings_OnChanged"
                                  Unchecked="MeetingAssistantSettings_OnChanged" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                           Text="DEFAULT POLICY" />
                                <ComboBox x:Name="MeetingRecordingPolicyComboBox"
                                          Margin="0,5,0,0"
                                          MinHeight="28"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectionChanged="MeetingAssistantSettings_OnSelectionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                           Text="LANGUAGE" />
                                <ComboBox x:Name="MeetingLanguageComboBox"
                                          Margin="0,5,0,0"
                                          MinHeight="28"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectionChanged="MeetingAssistantSettings_OnSelectionChanged" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                       Text="RECORDING FORMAT" />
                            <ComboBox x:Name="MeetingRecordingFormatComboBox"
                                      Margin="0,5,0,0"
                                      MinHeight="28"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectionChanged="MeetingAssistantSettings_OnSelectionChanged" />
                            <TextBlock Margin="0,5,0,0"
                                       Style="{StaticResource AppSubtitleStyle}"
                                       Text="Compact records directly to AAC/M4A. Lossless WAV uses substantially more disk space. The format applies only to new recordings."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                           Text="MICROPHONE" />
                                <ComboBox x:Name="MeetingMicrophoneComboBox"
                                          Margin="0,5,0,0"
                                          MinHeight="28"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Id"
                                          SelectionChanged="MeetingAssistantSettings_OnSelectionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                           Text="SYSTEM OUTPUT" />
                                <ComboBox x:Name="MeetingSystemOutputComboBox"
                                          Margin="0,5,0,0"
                                          MinHeight="28"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Id"
                                          SelectionChanged="MeetingAssistantSettings_OnSelectionChanged" />
                            </StackPanel>
                        </Grid>
                        <CheckBox x:Name="AutoTranscribeMeetingCheckBox"
                                  Margin="0,11,0,0"
                                  VerticalContentAlignment="Center"
                                  Foreground="{StaticResource AppTextBrush}"
                                  FontSize="11"
                                  Content="Auto-transcribe after Stop"
                                  Checked="MeetingAssistantSettings_OnChanged"
                                  Unchecked="MeetingAssistantSettings_OnChanged" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                           Text="TRANSCRIPTION - OPENAI" />
                                <TextBox x:Name="MeetingTranscriptionModelTextBox"
                                         Margin="0,5,0,0"
                                         Style="{StaticResource AppTextBoxStyle}"
                                         LostKeyboardFocus="MeetingAssistantSettings_OnLostKeyboardFocus" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                           Text="ANALYSIS - OPENAI" />
                                <TextBox x:Name="MeetingAnalysisModelTextBox"
                                         Margin="0,5,0,0"
                                         Style="{StaticResource AppTextBoxStyle}"
                                         LostKeyboardFocus="MeetingAssistantSettings_OnLostKeyboardFocus" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource AppSubtitleStyle}"
                                   Text="Auto-transcribe remains off until explicitly enabled. The first upload also requires disclosure confirmation in Workspace."
                                   TextWrapping="Wrap" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="OpenAiApiKeyPasswordBox"
                                         MinHeight="28" />
                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Update key"
                                    Click="UpdateOpenAiApiKeyButton_OnClick" />
                            <Button Grid.Column="2"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Remove key"
                                    Click="ClearOpenAiApiKeyButton_OnClick" />
                        </Grid>
                        <TextBlock x:Name="OpenAiApiKeyStatusText"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource AppSubtitleStyle}"
                                   TextWrapping="Wrap" />
                        <WrapPanel Margin="0,10,0,0">
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Open recordings folder"
                                    Click="OpenMeetingRecordingsFolderButton_OnClick" />
                        </WrapPanel>
                        <TextBlock Style="{StaticResource AppSubtitleStyle}"
                                   Text="Audio and derived files stay under the local recordings folder and are not copied by automatic state backups. The API key is protected for this Windows user and is not stored in state.json."
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="MeetingAssistantStatusText"
                                   Margin="0,7,0,0"
                                   Style="{StaticResource AppSubtitleStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="WORKING APPEARANCE" />
                        <Grid Margin="0,11,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="58" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32" />
                                <RowDefinition Height="32" />
                            </Grid.RowDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource AppTextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="Idle font" />
                            <Slider x:Name="WorkingIdleFontSizeSlider"
                                    Grid.Column="1"
                                    Margin="10,0"
                                    Style="{StaticResource AppSliderStyle}"
                                    Minimum="12"
                                    Maximum="24"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsSlider_OnValueChanged"
                                    PreviewMouseLeftButtonUp="SettingsSlider_OnPreviewMouseLeftButtonUp"
                                    LostKeyboardFocus="SettingsSlider_OnLostKeyboardFocus"
                                    KeyUp="SettingsSlider_OnKeyUp" />
                            <TextBlock x:Name="WorkingIdleFontSizeValue"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="#FFB8C1CD"
                                       FontFamily="Consolas"
                                       FontSize="10" />
                            <TextBlock Grid.Row="1"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource AppTextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="Active font" />
                            <Slider x:Name="WorkingActiveFontSizeSlider"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="10,0"
                                    Style="{StaticResource AppSliderStyle}"
                                    Minimum="12"
                                    Maximum="24"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsSlider_OnValueChanged"
                                    PreviewMouseLeftButtonUp="SettingsSlider_OnPreviewMouseLeftButtonUp"
                                    LostKeyboardFocus="SettingsSlider_OnLostKeyboardFocus"
                                    KeyUp="SettingsSlider_OnKeyUp" />
                            <TextBlock x:Name="WorkingActiveFontSizeValue"
                                       Grid.Row="1"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="#FFB8C1CD"
                                       FontFamily="Consolas"
                                       FontSize="10" />
                        </Grid>
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource AppSubtitleStyle}">
                            <Run Text="Working shows " />
                            <Run Foreground="#FFE5C469" FontWeight="SemiBold" Text="FOCUS" />
                            <Run Text=" tasks and active " />
                            <Run Foreground="#FFF0A86B" FontWeight="SemiBold" Text="REMIND" />
                            <Run Text=" items. Idle size applies when the pointer is away; active size applies on hover." />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="WINDOW SIZES" />
                        <TextBlock Margin="0,9,0,4"
                                   Foreground="#FF777F8B"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Text="WORKING PANEL" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="58" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32" />
                                <RowDefinition Height="32" />
                            </Grid.RowDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource AppTextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="Width" />
                            <Slider x:Name="WorkingWindowWidthSlider"
                                    Grid.Column="1"
                                    Margin="10,0"
                                    Style="{StaticResource AppSliderStyle}"
                                    Minimum="240"
                                    Maximum="600"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsSlider_OnValueChanged"
                                    PreviewMouseLeftButtonUp="SettingsSlider_OnPreviewMouseLeftButtonUp"
                                    LostKeyboardFocus="SettingsSlider_OnLostKeyboardFocus"
                                    KeyUp="SettingsSlider_OnKeyUp" />
                            <TextBlock x:Name="WorkingWindowWidthValue"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="#FFB8C1CD"
                                       FontFamily="Consolas"
                                       FontSize="10" />
                            <TextBlock Grid.Row="1"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource AppTextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="Height" />
                            <Slider x:Name="WorkingWindowHeightSlider"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="10,0"
                                    Style="{StaticResource AppSliderStyle}"
                                    Minimum="120"
                                    Maximum="800"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsSlider_OnValueChanged"
                                    PreviewMouseLeftButtonUp="SettingsSlider_OnPreviewMouseLeftButtonUp"
                                    LostKeyboardFocus="SettingsSlider_OnLostKeyboardFocus"
                                    KeyUp="SettingsSlider_OnKeyUp" />
                            <TextBlock x:Name="WorkingWindowHeightValue"
                                       Grid.Row="1"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="#FFB8C1CD"
                                       FontFamily="Consolas"
                                       FontSize="10" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="GLOBAL HOTKEYS" />
                        <ItemsControl x:Name="HotkeyItems" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,7"
                                            BorderBrush="#FF292D34"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{StaticResource AppTextBrush}"
                                                       FontSize="11"
                                                       Text="{Binding Label}" />
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal">
                                                <Border Padding="5,2"
                                                        Background="#FF0F1114"
                                                        BorderBrush="#FF30343B"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                    <TextBlock Foreground="#FFCDD2DA"
                                                               FontFamily="Consolas"
                                                               FontSize="9"
                                                               Text="Ctrl" />
                                                </Border>
                                                <Border Margin="4,0,0,0"
                                                        Padding="5,2"
                                                        Background="#FF0F1114"
                                                        BorderBrush="#FF30343B"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                    <TextBlock Foreground="#FFCDD2DA"
                                                               FontFamily="Consolas"
                                                               FontSize="9"
                                                               Text="Alt" />
                                                </Border>
                                                <Border Margin="4,0,0,0"
                                                        MinWidth="25"
                                                        Padding="5,2"
                                                        Background="#FF0F1114"
                                                        BorderBrush="#FF30343B"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               Foreground="#FFCDD2DA"
                                                               FontFamily="Consolas"
                                                               FontSize="9"
                                                               Text="{Binding Key}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid Margin="0,10,0,0">
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource AppSubtitleStyle}"
                                       Text="Hotkeys are fixed for now." />
                            <Button HorizontalAlignment="Right"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Edit hotkeys - Coming later"
                                    IsEnabled="False" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="BACKUPS" />
                        <CheckBox x:Name="BackupsEnabledCheckBox"
                                  Margin="0,10,0,0"
                                  VerticalContentAlignment="Center"
                                  Foreground="{StaticResource AppTextBrush}"
                                  FontSize="11"
                                  Content="Enable automatic backups"
                                  Checked="BackupsEnabledCheckBox_OnChanged"
                                  Unchecked="BackupsEnabledCheckBox_OnChanged" />
                        <TextBox x:Name="BackupFolderTextBox"
                                 Margin="0,10,0,0"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 IsReadOnly="True"
                                 ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        <WrapPanel Margin="0,9,0,0">
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Choose folder"
                                    Click="ChooseBackupFolderButton_OnClick" />
                            <Button x:Name="OpenBackupFolderButton"
                                    Margin="0,0,8,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Open folder"
                                    Click="OpenBackupFolderButton_OnClick" />
                            <Button x:Name="BackupNowButton"
                                    Margin="0,0,8,8"
                                    Style="{StaticResource AppPrimaryButtonStyle}"
                                    Content="Backup now"
                                    Click="BackupNowButton_OnClick" />
                            <Button x:Name="CheckBackupFolderButton"
                                    Margin="0,0,8,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Check backup folder"
                                    Click="CheckBackupFolderButton_OnClick" />
                            <Button x:Name="RestoreLatestBackupButton"
                                    Margin="0,0,0,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Restore latest backup"
                                    Click="RestoreLatestBackupButton_OnClick" />
                        </WrapPanel>
                        <TextBlock x:Name="BackupPolicyText"
                                   Style="{StaticResource AppSubtitleStyle}" />
                        <TextBlock x:Name="BackupStatusText"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource AppSubtitleStyle}" />
                        <Border Margin="0,10,0,0"
                                Padding="10"
                                Background="#FF15181D"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock x:Name="BackupLocalStateText"
                                           Foreground="{StaticResource AppTextBrush}"
                                           FontSize="11" />
                                <TextBlock x:Name="BackupLatestStateText"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource AppTextBrush}"
                                           FontSize="11" />
                                <TextBlock x:Name="BackupFreshnessText"
                                           Margin="0,6,0,0"
                                           Foreground="#FFE5C469"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="BackupRestoreWarningText"
                                           Margin="0,6,0,0"
                                           Foreground="#FFDB646A"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="This backup is older than your local state. Restoring it will replace newer local data."
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="TELEGRAM CAPTURE" />
                        <CheckBox x:Name="TelegramEnabledCheckBox"
                                  Margin="0,10,0,0"
                                  VerticalContentAlignment="Center"
                                  Foreground="{StaticResource AppTextBrush}"
                                  FontSize="11"
                                  Content="Enable Telegram Capture setup"
                                  Checked="TelegramSettings_OnChanged"
                                  Unchecked="TelegramSettings_OnChanged" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                           Text="BOT USERNAME" />
                                <TextBox x:Name="TelegramBotUsernameTextBox"
                                         Margin="0,5,0,0"
                                         Style="{StaticResource AppTextBoxStyle}"
                                         LostKeyboardFocus="TelegramSettings_OnLostKeyboardFocus" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                           Text="ALLOWED USER ID" />
                                <TextBox x:Name="TelegramAllowedUserIdTextBox"
                                         Margin="0,5,0,0"
                                         Style="{StaticResource AppTextBoxStyle}"
                                         LostKeyboardFocus="TelegramSettings_OnLostKeyboardFocus" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                           Text="DEFAULT PROJECT" />
                                <ComboBox x:Name="TelegramDefaultProjectComboBox"
                                          Margin="0,5,0,0"
                                          MinHeight="28"
                                          SelectionChanged="TelegramDefaultProjectComboBox_OnSelectionChanged"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                           Text="BOT TOKEN" />
                                <PasswordBox x:Name="TelegramTokenPasswordBox"
                                             Margin="0,5,0,0"
                                             MinHeight="28" />
                            </StackPanel>
                        </Grid>
                        <WrapPanel Margin="0,10,0,0">
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Update token"
                                    Click="UpdateTelegramTokenButton_OnClick" />
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Clear token"
                                    Click="ClearTelegramTokenButton_OnClick" />
                            <Button x:Name="TestTelegramConnectionButton"
                                    Margin="0,0,8,8"
                                    Style="{StaticResource AppPrimaryButtonStyle}"
                                    Content="Test connection"
                                    Click="TestTelegramConnectionButton_OnClick" />
                        </WrapPanel>
                        <TextBlock Margin="0,2,0,0"
                                   Style="{StaticResource AppSubtitleStyle}"
                                   Text="Token is stored with Windows user protection and is not written to state.json." />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource AppSectionLabelStyle}"
                                   Text="PROJECT ALIASES" />
                        <TextBox x:Name="TelegramAliasesTextBox"
                                 Margin="0,5,0,0"
                                 Height="78"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 LostKeyboardFocus="TelegramSettings_OnLostKeyboardFocus" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource AppSubtitleStyle}"
                                   Text="One alias per line: alias = Project name. Matching is case-insensitive in future polling." />
                        <TextBlock x:Name="TelegramStatusText"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource AppSubtitleStyle}" />

                        <TextBlock Margin="0,14,0,0"
                                   Style="{StaticResource AppSectionLabelStyle}"
                                   Text="STATUS" />
                        <TextBlock x:Name="TelegramRuntimeStatusText"
                                   Margin="0,5,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AppTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="TelegramRuntimeDetailText"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource AppSubtitleStyle}" />
                        <TextBlock x:Name="TelegramRuntimeErrorText"
                                   Margin="0,4,0,0"
                                   Foreground="#FFDB646A"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />
                        <WrapPanel Margin="0,8,0,0">
                            <Button x:Name="PollTelegramNowButton"
                                    Margin="0,0,8,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Check now"
                                    Click="PollTelegramNowButton_OnClick" />
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Open ContextHUB"
                                    Click="OpenTelegramContextHubButton_OnClick" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource AppCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource AppSectionLabelStyle}"
                                   Text="DIAGNOSTICS &amp; STORAGE" />
                        <WrapPanel Margin="0,10,0,0">
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Open logs"
                                    Click="OpenLogsButton_OnClick" />
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Open state folder"
                                    Click="OpenStateFolderButton_OnClick" />
                            <Button Margin="0,0,0,8"
                                    Style="{StaticResource AppButtonStyle}"
                                    Content="Reset window positions"
                                    Click="ResetWindowPositionsButton_OnClick" />
                        </WrapPanel>
                        <TextBlock x:Name="DiagnosticsStatusText"
                                   Style="{StaticResource AppSubtitleStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="18,11"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock VerticalAlignment="Center"
                           Foreground="#FF7F8793"
                           FontSize="10"
                           Text="Changes apply instantly." />
                <Button HorizontalAlignment="Right"
                        MinWidth="72"
                        Style="{StaticResource AppButtonStyle}"
                        Content="Close"
                        IsCancel="True"
                        Click="CloseButton_OnClick" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
