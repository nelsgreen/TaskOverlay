<UserControl x:Class="TaskOverlay.App.ReminderPresetSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ListBox x:Name="PresetListBox"
             Style="{StaticResource AppChipListStyle}"
             ItemContainerStyle="{StaticResource AppChipItemStyle}"
             SelectionChanged="PresetListBox_OnSelectionChanged">
        <ListBox.ItemTemplate>
            <DataTemplate>
                <TextBlock FontSize="11"
                           FontWeight="SemiBold"
                           Text="{Binding Label}" />
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
