<UserControl x:Class="TaskOverlay.App.ReminderEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="ReminderToggleStyle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Content" Value="OFF" />
            <Setter Property="Foreground" Value="#FFA1A1AA" />
            <Setter Property="Background" Value="#FF24272E" />
            <Setter Property="BorderBrush" Value="#FF454A55" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="ON" />
                                <Setter Property="Foreground" Value="#FF111318" />
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#FFF4B942" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#FFFFCF66" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReminderButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AppButtonStyle}">
            <Setter Property="MinHeight" Value="27" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="FontSize" Value="10" />
        </Style>

        <Style x:Key="ReminderInputStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource AppTextBoxStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource AppCardStyle}">
        <StackPanel>
            <DockPanel x:Name="HeaderPanel" Margin="0,0,0,8">
                <TextBlock VerticalAlignment="Center"
                           Foreground="#FFF4B942"
                           FontSize="10"
                           FontWeight="Bold"
                           Text="REMIND" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Border x:Name="SummaryBorder"
                            Margin="0,0,7,0"
                            Padding="8,4"
                            VerticalAlignment="Center"
                            Background="#332D2411"
                            BorderBrush="#FF72571E"
                            BorderThickness="1"
                            CornerRadius="11">
                        <TextBlock x:Name="SummaryText"
                                   Foreground="#FFF4B942"
                                   FontFamily="Consolas"
                                   FontSize="9" />
                    </Border>
                    <ToggleButton x:Name="ReminderToggleButton"
                                  Style="{StaticResource ReminderToggleStyle}"
                                  Checked="ReminderToggleButton_OnChanged"
                                  Unchecked="ReminderToggleButton_OnChanged" />
                </StackPanel>
            </DockPanel>

            <ListBox x:Name="PresetListBox"
                     Style="{StaticResource AppChipListStyle}"
                     ItemContainerStyle="{StaticResource AppChipItemStyle}"
                     SelectionChanged="PresetListBox_OnSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontSize="10" Text="{Binding Label}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel x:Name="SchedulePanel" Margin="0,3,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <WrapPanel Grid.Column="0">
                        <DatePicker x:Name="ReminderDatePicker"
                                Width="126"
                                Height="30"
                                Margin="0,0,7,6"
                                Padding="4"
                                Foreground="#FFF4F4F5"
                                Background="#FF24272E"
                                BorderBrush="#FF454A55"
                                SelectedDateFormat="Short"
                                SelectedDateChanged="ReminderDatePicker_OnSelectedDateChanged">
                        <DatePicker.Resources>
                            <Style TargetType="{x:Type DatePickerTextBox}">
                                <Setter Property="Foreground" Value="#FFF4F4F5" />
                                <Setter Property="Background" Value="#FF24272E" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="CaretBrush" Value="#FFFFFFFF" />
                                <Setter Property="Padding" Value="4,0" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>
                        </DatePicker.Resources>
                        </DatePicker>
                        <TextBox x:Name="ReminderTimeTextBox"
                             Width="62"
                             Margin="0,0,7,6"
                             Style="{StaticResource ReminderInputStyle}"
                             HorizontalContentAlignment="Center"
                             MaxLength="5"
                             ToolTip="Time in HH:mm format"
                             LostKeyboardFocus="ReminderTimeTextBox_OnLostKeyboardFocus"
                             KeyDown="ReminderTimeTextBox_OnKeyDown" />
                        <Button Style="{StaticResource ReminderButtonStyle}"
                            Content="+10m"
                            Click="Add10MinutesButton_OnClick" />
                        <Button Style="{StaticResource ReminderButtonStyle}"
                            Content="+30m"
                            Click="Add30MinutesButton_OnClick" />
                        <Button Style="{StaticResource ReminderButtonStyle}"
                            Content="+1h"
                            Click="Add1HourButton_OnClick" />
                        <Button Style="{StaticResource ReminderButtonStyle}"
                            Content="+1d"
                            Click="Add1DayButton_OnClick" />
                    </WrapPanel>
                    <Button x:Name="RepeatButton"
                            Grid.Column="1"
                            Margin="6,0,0,6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Style="{StaticResource ReminderButtonStyle}"
                            Content="Repeat"
                            Click="RepeatButton_OnClick" />
                </Grid>

                <StackPanel x:Name="AdvancedPanel" Visibility="Collapsed">
                    <Separator Margin="0,1,0,7" Background="#FF343842" />
                    <DockPanel>
                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource AppSectionLabelStyle}"
                                   Text="REPEAT" />
                        <ListBox x:Name="RepeatListBox"
                                 Style="{StaticResource AppChipListStyle}"
                                 ItemContainerStyle="{StaticResource AppChipItemStyle}"
                                 SelectionChanged="RepeatListBox_OnSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="10" Text="{Binding Label}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
