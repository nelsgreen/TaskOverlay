<Window x:Class="TaskOverlay.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskOverlay v2 Settings"
        Width="520"
        Height="340"
        MinWidth="420"
        MinHeight="260"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FF181B22">
        <StackPanel Margin="32">
            <TextBlock Foreground="#FFF4F4F5"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Text="Settings" />
            <TextBlock Margin="0,14,0,0"
                       Foreground="#FFA1A1AA"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Text="Prototype placeholder. Settings editing, themes, hotkeys, and v1 migration are intentionally out of scope." />
        </StackPanel>
    </Grid>
</Window>
