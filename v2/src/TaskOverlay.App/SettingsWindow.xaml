<Window x:Class="TaskOverlay.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskOverlay v2 Settings"
        Width="520"
        Height="600"
        MinWidth="420"
        MinHeight="320"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FF181B22">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32">
                <TextBlock Foreground="#FFF4F4F5"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Text="Settings" />
                <TextBlock Margin="0,14,0,0"
                           Foreground="#FFA1A1AA"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Text="Focused-task behavior is editable here. Themes, editable hotkeys, and v1 migration remain outside this prototype." />
                <Border Margin="0,24,0,18"
                        Height="1"
                        Background="#FF3F3F46" />
                <TextBlock Foreground="#FFF4F4F5"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="Focus mode" />
                <ComboBox x:Name="InWorkModeComboBox"
                          Width="220"
                          Margin="0,12,0,0"
                          HorizontalAlignment="Left"
                          SelectionChanged="InWorkModeComboBox_OnSelectionChanged">
                    <ComboBoxItem Tag="MultipleTasks"
                                  Content="Multiple tasks" />
                    <ComboBoxItem Tag="SingleTask"
                                  Content="Single task" />
                </ComboBox>
                <TextBlock Margin="0,8,0,0"
                           Foreground="#FFA1A1AA"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Text="Multiple tasks toggles focus independently. Single task clears focus from every other task." />
                <Border Margin="0,24,0,18"
                        Height="1"
                        Background="#FF3F3F46" />
                <TextBlock Foreground="#FFF4F4F5"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="Fixed global hotkeys" />
                <TextBlock Margin="0,12,0,0"
                           Foreground="#FFD4D4D8"
                           FontFamily="Consolas"
                           FontSize="14"
                           Text="Ctrl+Alt+A   Create tasks from clipboard lines" />
                <TextBlock Margin="0,7,0,0"
                           Foreground="#FFD4D4D8"
                           FontFamily="Consolas"
                           FontSize="14"
                           Text="Ctrl+Alt+S   Create one task from clipboard" />
                <TextBlock Margin="0,7,0,0"
                           Foreground="#FFD4D4D8"
                           FontFamily="Consolas"
                           FontSize="14"
                           Text="Ctrl+Alt+D   Create one task with description" />
                <TextBlock Margin="0,7,0,0"
                           Foreground="#FFD4D4D8"
                           FontFamily="Consolas"
                           FontSize="14"
                           Text="Ctrl+Alt+T   Show or hide overlay" />
                <TextBlock Margin="0,7,0,0"
                           Foreground="#FFD4D4D8"
                           FontFamily="Consolas"
                           FontSize="14"
                           Text="Ctrl+Alt+Q   Quick Add task" />
                <TextBlock Margin="0,14,0,0"
                           Foreground="#FFA1A1AA"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Text="These bindings are fixed. Registration failures are logged if another application owns a shortcut." />
                <Border Margin="0,24,0,18"
                        Height="1"
                        Background="#FF3F3F46" />
                <TextBlock Foreground="#FFF4F4F5"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="Overlay state" />
                <TextBlock x:Name="OverlayModeStatus"
                           Margin="0,12,0,0"
                           Foreground="#FFD4D4D8"
                           FontSize="14" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
