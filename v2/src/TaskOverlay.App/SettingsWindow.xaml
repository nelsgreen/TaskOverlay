<Window x:Class="TaskOverlay.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskOverlay v2 Settings"
        Width="520"
        Height="430"
        MinWidth="420"
        MinHeight="260"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FF181B22">
        <StackPanel Margin="32">
            <TextBlock Foreground="#FFF4F4F5"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Text="Settings" />
            <TextBlock Margin="0,14,0,0"
                       Foreground="#FFA1A1AA"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Text="Prototype placeholder. Editable settings, themes, and v1 migration are intentionally out of scope." />
            <Border Margin="0,24,0,18"
                    Height="1"
                    Background="#FF3F3F46" />
            <TextBlock Foreground="#FFF4F4F5"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Text="Fixed global hotkeys" />
            <TextBlock Margin="0,12,0,0"
                       Foreground="#FFD4D4D8"
                       FontFamily="Consolas"
                       FontSize="14"
                       Text="Ctrl+Alt+A   Create tasks from clipboard lines" />
            <TextBlock Margin="0,7,0,0"
                       Foreground="#FFD4D4D8"
                       FontFamily="Consolas"
                       FontSize="14"
                       Text="Ctrl+Alt+S   Create one task from clipboard" />
            <TextBlock Margin="0,7,0,0"
                       Foreground="#FFD4D4D8"
                       FontFamily="Consolas"
                       FontSize="14"
                       Text="Ctrl+Alt+D   Create one task with description" />
            <TextBlock Margin="0,7,0,0"
                       Foreground="#FFD4D4D8"
                       FontFamily="Consolas"
                       FontSize="14"
                       Text="Ctrl+Alt+T   Show or hide overlay" />
            <TextBlock Margin="0,14,0,0"
                       Foreground="#FFA1A1AA"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Text="These bindings are fixed in this prototype. Registration failures are logged if another application already owns a shortcut." />
        </StackPanel>
    </Grid>
</Window>
