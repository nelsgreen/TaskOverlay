<UserControl x:Class="TaskOverlay.App.WindowSwitcherControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <Border Padding="3"
            HorizontalAlignment="Center"
            Background="#FF15171B"
            BorderBrush="#FF343840"
            BorderThickness="1"
            CornerRadius="9">
        <StackPanel Orientation="Horizontal">
            <ToggleButton x:Name="QuickAddButton"
                          Style="{StaticResource AppSwitcherTabStyle}"
                          Content="Quick Add"
                          Click="QuickAddButton_OnClick" />
            <ToggleButton x:Name="TaskDetailsButton"
                          Style="{StaticResource AppSwitcherTabStyle}"
                          Content="Task Details"
                          Click="TaskDetailsButton_OnClick" />
            <ToggleButton x:Name="SettingsButton"
                          Style="{StaticResource AppSwitcherTabStyle}"
                          Content="Settings"
                          Click="SettingsButton_OnClick" />
        </StackPanel>
    </Border>
</UserControl>
