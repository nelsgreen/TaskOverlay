<Window x:Class="TaskOverlay.App.UtilityShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TaskOverlay.App"
        Title="TaskOverlay"
        Icon="Assets/taskoverlay.ico"
        Width="680"
        Height="820"
        MinWidth="600"
        MinHeight="680"
        Background="{StaticResource AppWindowBrush}"
        FontFamily="Segoe UI"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <local:WindowSwitcherControl x:Name="WindowSwitcher"
                                     Grid.Row="0"
                                     Margin="14,12,14,8" />

        <ContentControl x:Name="ContentHost" Grid.Row="1" />
    </Grid>
</Window>
