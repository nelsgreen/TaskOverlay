<Window x:Class="TaskOverlay.App.DueAttentionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reminders"
        Width="340"
        MaxHeight="420"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False">
    <Window.Resources>
        <Style x:Key="RemindButtonBase" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Foreground" Value="#FFF4F4F5" />
            <Setter Property="Background" Value="#FF303540" />
            <Setter Property="BorderBrush" Value="#FF525866" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.68" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FocusButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource RemindButtonBase}">
            <Setter Property="Background" Value="#FF2563EB" />
            <Setter Property="BorderBrush" Value="#FF60A5FA" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="EditButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource RemindButtonBase}">
            <Setter Property="Background" Value="#FF3F3F46" />
            <Setter Property="BorderBrush" Value="#FF71717A" />
        </Style>
        <Style x:Key="SnoozeButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource RemindButtonBase}" />
        <Style x:Key="RemoveButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource RemindButtonBase}">
            <Setter Property="Foreground" Value="#FFFCD34D" />
            <Setter Property="Background" Value="#33271305" />
            <Setter Property="BorderBrush" Value="#FFB45309" />
        </Style>
        <Style x:Key="DoneButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource RemindButtonBase}">
            <Setter Property="Background" Value="#FF166534" />
            <Setter Property="BorderBrush" Value="#FF22C55E" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
    <Border Margin="8"
            Padding="12"
            Background="#F2181B22"
            BorderBrush="#FFEF4444"
            BorderThickness="1"
            CornerRadius="8">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="0,0,0,8"
                       Foreground="#FFFCA5A5"
                       FontSize="11"
                       FontWeight="Bold"
                       Text="REMIND" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="DueItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    Background="#FF242832"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Foreground="#FFFFFFFF"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}"
                                               TextWrapping="Wrap" />
                                    <UniformGrid Margin="0,10,0,0" Columns="2">
                                        <Button Margin="0,0,3,0"
                                                Style="{StaticResource FocusButtonStyle}"
                                                Tag="{Binding TaskId}"
                                                Click="Focus_OnClick"
                                                Content="Focus" />
                                        <Button Margin="3,0,0,0"
                                                Style="{StaticResource EditButtonStyle}"
                                                Tag="{Binding TaskId}"
                                                Click="EditTask_OnClick"
                                                Content="Edit task" />
                                    </UniformGrid>
                                    <UniformGrid Margin="0,6,0,0" Columns="2">
                                        <Button Margin="0,0,3,0"
                                                Style="{StaticResource SnoozeButtonStyle}"
                                                Tag="{Binding TaskId}"
                                                Click="Snooze30_OnClick"
                                                Content="Snooze 30m" />
                                        <Button Margin="3,0,0,0"
                                                Style="{StaticResource SnoozeButtonStyle}"
                                                Tag="{Binding TaskId}"
                                                Click="Snooze60_OnClick"
                                                Content="Snooze 60m" />
                                    </UniformGrid>
                                    <UniformGrid Margin="0,6,0,0" Columns="2">
                                        <Button Margin="0,0,3,0"
                                                Style="{StaticResource RemoveButtonStyle}"
                                                Tag="{Binding TaskId}"
                                                Click="Clear_OnClick"
                                                Content="Remove reminder" />
                                        <Button Margin="3,0,0,0"
                                                Style="{StaticResource DoneButtonStyle}"
                                                Tag="{Binding TaskId}"
                                                Click="Done_OnClick"
                                                Content="Done" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
